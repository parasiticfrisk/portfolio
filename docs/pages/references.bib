@misc{frisk_Díaz-Garayúa_2025,
	address = {New Orleans, LA, US},
	eventtitle = {American Geophysical Union},
	type = {Poster},
	title = {Building an open-source urban forestry model},
	copyright = {https://creativecommons.org/licenses/by-sa/4.0/},
	url = {https://essopenarchive.org/doi/full/10.22541/essoar.176892235.51073089/v1},
	doi = {10.22541/essoar.176892235.51073089/v1},
	abstract = {This project presents a refined, scalable workflow for participatory urban forestry data collection developed through ongoing HEX Lab research. The original reliance on i-Tree MyTree limited efficiency, multi-user coordination, and large-park survey capacity. In response, a new field data capture workflow was protoyped in ArcGIS Field Maps, streamlining survey inputs while retaining key ecological attributes required for downstream i-Tree Eco analysis. Field testing with volunteers of varying ages demonstrated substantial gains in usability and efficiency, enabling rapid collection of more than 1,000 trees across three parks in Turlock, California. Bulk ecological service calculations were completed through i-Tree Eco, supporting individual-level assessment without manual re-submission. This case study highlights an effective model for integrating community participation into a robust scientific workflow. Future efforts will focus on transitioning from proprietary GIS platforms to open-source tools and developing accessible data infrastructure to support long-term, community-driven urban ecological monitoring.},
	language = {en},
	author = {Frisk, August and Díaz-Garayúa, José},
	month = dec,
	year = {2025},
}

